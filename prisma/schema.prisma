generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  role          Role
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  is_active     Boolean

  mukhtarAssignmentsAssignedMukhtar mukhtar_assignments[] @relation("MukhtarAssignmentsMukhtar")
  mukhtarAssignmentsAssignedBy      mukhtar_assignments[] @relation("MukhtarAssignmentsAssignedBy")
  complaintsInitial                 complaints[]          @relation("MukhtarInitial")
  complaintTimelineActions          complaint_timeline[]
  announcementsCreated              announcements[]
  achievementsCreated               achievements[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  revoked   Boolean  @default(false)
  jti       String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  manager // super user:
  admin
  mukhtar
}

model neighborhoods {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  complaints  complaints[]
}

model complaint_types {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  isActive    Boolean      @default(true)
  complaints  complaints[]
}

model complaint_statuses {
  id                Int                  @id @default(autoincrement())
  code              String               @unique
  label             String
  sortOrder         Int                  @default(100)
  complaints        complaints[]
  complaintTimeline complaint_timeline[]
}

model complaints {
  id                     BigInt   @id @default(autoincrement())
  trackingCode           String?  @unique
  neighborhoodId         Int?
  complaintTypeId        Int?
  complaintStatusId      Int?
  mukhtarInitialId       String? // FK to User.id (mukhtar)
  description            String?
  canUserProvideSolution Boolean  @default(false)
  contactNumber          String
  submitterName          String?
  latitude               Decimal? @db.Decimal(9, 6)
  longitude              Decimal? @db.Decimal(9, 6)
  addressText            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @default(now())

  neighborhood    neighborhoods?      @relation(fields: [neighborhoodId], references: [id])
  complaintType   complaint_types?    @relation(fields: [complaintTypeId], references: [id])
  complaintStatus complaint_statuses? @relation(fields: [complaintStatusId], references: [id])
  mukhtarInitial  User?               @relation("MukhtarInitial", fields: [mukhtarInitialId], references: [id])

  complaintAttachments complaint_attachments[]
  complaintTimeline    complaint_timeline[]
  mukhtarAssignments   mukhtar_assignments[]
  achievements         achievements[]
  notificationsLog     notifications_log[]
}

model complaint_attachments {
  id          BigInt   @id @default(autoincrement())
  complaintId BigInt
  filePath    String
  fileType    String?
  caption     String?
  createdAt   DateTime @default(now())

  complaint complaints @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  achievements       achievements[]
  beforeAchievements achievements[] @relation("BeforeAttachment")
  afterAchievements  achievements[] @relation("AfterAttachment")
}

model complaint_timeline {
  id          BigInt   @id @default(autoincrement())
  complaintId BigInt
  actorId     String? // FK to User.id
  statusId    Int?
  note        String?
  metadata    Json?
  createdAt   DateTime @default(now())

  complaint complaints          @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  actor     User?               @relation(fields: [actorId], references: [id])
  status    complaint_statuses? @relation(fields: [statusId], references: [id])
}

model mukhtar_assignments {
  id           BigInt   @id @default(autoincrement())
  complaintId  BigInt
  mukhtarId    String?
  assignedById String?
  assignedAt   DateTime @default(now())
  notes        String?
  isActive     Boolean  @default(true)

  complaint  complaints @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  mukhtar    User?      @relation("MukhtarAssignmentsMukhtar", fields: [mukhtarId], references: [id])
  assignedBy User?      @relation("MukhtarAssignmentsAssignedBy", fields: [assignedById], references: [id])
}

model announcements {
  id          BigInt    @id @default(autoincrement())
  title       String
  body        String
  isPublic    Boolean   @default(true)
  startAt     DateTime?
  endAt       DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  creator User? @relation(fields: [createdById], references: [id])
}

model achievements {
  id                 BigInt   @id @default(autoincrement())
  complaintId        BigInt?
  title              String?
  description        String?
  beforeAttachmentId BigInt?
  afterAttachmentId  BigInt?
  createdById        String?
  createdAt          DateTime @default(now())

  complaint        complaints?            @relation(fields: [complaintId], references: [id])
  beforeAttachment complaint_attachments? @relation("BeforeAttachment", fields: [beforeAttachmentId], references: [id])
  afterAttachment  complaint_attachments? @relation("AfterAttachment", fields: [afterAttachmentId], references: [id])
  creator          User?                  @relation(fields: [createdById], references: [id])

  complaintAttachments complaint_attachments[]
}

model notifications_log {
  id               BigInt   @id @default(autoincrement())
  complaintId      BigInt?
  toNumber         String?
  channel          String?
  message          String?
  providerResponse Json?
  sentAt           DateTime @default(now())
  status           String?

  complaint complaints? @relation(fields: [complaintId], references: [id])
}

model system_settings {
  keyName   String   @id
  value     String?
  updatedAt DateTime @default(now())
}
