generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// System users with roles: manager (superuser), admin, mukhtar
model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role
  is_active    Boolean

  complaintsHandled complaints[] @relation("MukhtarInitial") // complaints accepted by this mukhtar

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  refreshTokens RefreshToken[]
}

// Refresh tokens for user sessions
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

// Enumeration of roles in the system
enum Role {
  manager // superuser role
  admin
  mukhtar
}

// Complaints submitted by website users (no account needed)
model complaints {
  id                BigInt   @id @default(autoincrement())
  submitterName     String?  // Name of submitter, no account needed
  contactNumber     String
  description       String?
  location          String?
  neighborhoodId    Int?
  complaintTypeId   Int?
  complaintStatusId Int?     // status like accepted/refused/pending
  mukhtarInitialId  String?  // mukhtar who accepted (nullable)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now())
  deletedAt         DateTime? // soft delete timestamp; null means active

  neighborhood  neighborhoods?      @relation(fields: [neighborhoodId], references: [id])
  complaintType complaint_types?    @relation(fields: [complaintTypeId], references: [id])
  status        complaint_statuses? @relation(fields: [complaintStatusId], references: [id])
  handler       User?               @relation("MukhtarInitial", fields: [mukhtarInitialId], references: [id])
}

// Neighborhoods for complaints categorization
model neighborhoods {
  id         Int          @id @default(autoincrement())
  name       String       @unique
  createdAt  DateTime     @default(now())
  complaints complaints[]
}

// Complaint types: e.g. noise, sanitation, traffic
model complaint_types {
  id         Int          @id @default(autoincrement())
  name       String       @unique
  complaints complaints[]
}

// Statuses: e.g. pending, accepted, refused
model complaint_statuses {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  label       String
  complaints  complaints[]
}
